<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FileOrganizer.GUI.MainWindow"
        Title="File Organizer">

    <Grid RowDefinitions="Auto,*,Auto" Margin="10">

        <!-- Top Row: Folder Selection -->
        <Button Grid.Row="0" Name="SelectFolderButton" Content="Select Folder to Organize" HorizontalAlignment="Stretch" />

        <!-- Middle Row: File List -->
        <ListBox Grid.Row="1" Name="FileListBox" Margin="0,10,0,10" />

        <!-- Bottom Row: Organize Button -->
        <Button Grid.Row="2" Name="OrganizeButton" Content="Organize Files" HorizontalAlignment="Stretch" />

    </Grid>

</Window>
